# Required
AZDO_ORG=your-azure-devops-org-name

# Optional - comma separated list of allowed projects
# Leave EMPTY to allow ALL projects
# AZDO_PROJECT_ALLOWLIST=Project1,Project2,Project3

# Optional
PORT=3000
LOG_LEVEL=info

# Optional - comma separated allowed hostnames
# Must include your domain
ALLOWED_HOSTS=yourdomain.com
